{
  "nodeEnv": "development",
  "logging": {
    "level": "debug",
    "verbose": false
  },
  "llm": {
    "baseUrl": "https://lite-llm.lan/v1",
    "apiKey": "check-env-variable",
    "model": "qwen3.5-27b",
    "provider": "openai",
    "temperature": 0.6,
    "maxTokens": 10000,
    "topP": 0.95,
    "topK": 20,
    "minP": 0
  },
  "mcp": {
    "gatewayUrl": "http://mcp-gateway.mammoth.lan/mcp"
  },
  "langfuse": {
    "baseUrl": "http://langfuse.mammoth.lan",
    "publicKey": "check-env-variable",
    "secretKey": "check-env-variable",
    "enabled": true
  },
  "runtime": {
    "port": 3002
  }
}