{
  "name": "zyreth-openai-gateway",
  "version": "0.1.0",
  "description": "OpenAI-compatible HTTP gateway for the Zyreth Mastra agent",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "build": "npx nest build",
    "dev": "npm run infisical:run -- npx nest start --watch",
    "start": "npm run infisical:run -- env NODE_ENV=production node dist/main.js",
    "infisical:run": "./scripts/infisical-run.sh",
    "code:check": "npm run lint:check && npm run prettier:check && npm run ts:check",
    "code:fix": "npm run lint:fix && npm run prettier:write",
    "lint:check": "ESLINT_USE_FLAT_CONFIG=true eslint --config ./eslint.config.js --cache . --max-warnings 0",
    "lint:fix": "ESLINT_USE_FLAT_CONFIG=true eslint --config ./eslint.config.js --cache . --max-warnings 0 --fix",
    "prettier:check": "prettier --check \"{src,test}/**/*.{ts,js,json,md}\"",
    "prettier:write": "prettier --write \"{src,test}/**/*.{ts,js,json,md}\"",
    "ts:check": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@mastra/core": "1.17.0",
    "@nestjs/common": "11.1.17",
    "@nestjs/config": "4.0.3",
    "@nestjs/core": "11.1.17",
    "@nestjs/platform-express": "11.1.17",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "config": "4.4.1",
    "nestjs-pino": "4.6.1",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.16",
    "@types/express": "5.0.6",
    "pino-pretty": "13.1.3",
    "ts-node": "10.9.2"
  }
}
